@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# =====================================================================
# Local class declarations (refinements of PROV-O core classes)
# =====================================================================

oid:Claim                  rdfs:subClassOf prov:Entity ;
  rdfs:comment "A load-bearing assertion in the paper, addressable by section anchor." .
oid:Source                 rdfs:subClassOf prov:Entity ;
  rdfs:comment "A literature-register (L-XX-N) or code-side (S-XX-N) source." .
oid:Transcript             rdfs:subClassOf prov:Entity ;
  rdfs:comment "An exported AI conversation, archived in experiments/*/raw_conversations*/." .
oid:Figure                 rdfs:subClassOf prov:Entity ;
  rdfs:comment "A figure in paper/figures/, paired with data + script under rule 15." .
oid:Commit                 rdfs:subClassOf prov:Entity ;
  rdfs:comment "A git commit, identified by oid:commit-<sha7>." .
oid:VerificationStatus     rdfs:subClassOf prov:Entity ;
  rdfs:comment "A rung on the docs/sources.md verification ladder." .
oid:PipelineStage          rdfs:subClassOf prov:Activity ;
  rdfs:comment "One of the eight pipeline stages defined in CLAUDE.md." .
oid:Build                  rdfs:subClassOf prov:Activity ;
  rdfs:comment "A make all invocation, including SHAs of generated PDFs." .
oid:AIAgent                rdfs:subClassOf prov:Agent ;
  rdfs:comment "A model + harness combination, e.g. Claude Opus 4.7 + Claude Code CLI." .
oid:HumanResearcher        rdfs:subClassOf prov:Agent .

# =====================================================================
# Verification-status individuals (the ladder)
# =====================================================================

oid:unverified-external a oid:VerificationStatus ;
  dct:title "[unverified-external]" ;
  rdfs:comment "URL or formal citation surfaced in a transcript; not yet retrieved." .
oid:needs-research a oid:VerificationStatus ;
  dct:title "[needs-research]" ;
  rdfs:comment "Gap or open question requiring literature search." .
oid:lit-retrieved a oid:VerificationStatus ;
  dct:title "[lit-retrieved]" ;
  rdfs:comment "Title, authors, abstract, venue, citation count, DOI/URL recorded; full text unread." .
oid:ai-confirmed a oid:VerificationStatus ;
  dct:title "[ai-confirmed]" ;
  rdfs:comment "Source Analyzer agent has retrieved + read full text + confirmed entry summary." .
oid:lit-read a oid:VerificationStatus ;
  dct:title "[lit-read]" ;
  rdfs:comment "Full text read by a human; required for contested or first-of-its-kind claims." .

